# Milestone 1 works without secrets. Mock values are development-only.
APP_RUNTIME_MODE=mock
BITRIX24_MODE=mock

# Required only for future live integrations. Never prefix these with NEXT_PUBLIC_.
BITRIX24_PORTAL_URL=
BITRIX24_WEBHOOK_URL=
BITRIX24_TIMEZONE=Europe/Moscow

# Temporary local OAuth/portal-identity spike. It is always disabled in production.
# Keep client credentials only in an ignored local environment file.
BITRIX24_OAUTH_SPIKE_ENABLED=false
BITRIX24_OAUTH_SPIKE_APP_ORIGIN=
BITRIX24_OAUTH_SPIKE_PORTAL_ORIGIN=
BITRIX24_OAUTH_SPIKE_EXPECTED_MEMBER_ID=
BITRIX24_OAUTH_SPIKE_CLIENT_ID=
BITRIX24_OAUTH_SPIKE_CLIENT_SECRET=
BITRIX24_OAUTH_SPIKE_REDIRECT_URI=
# Choose exactly one of user_brief, user_basic, or user; optional basic may be added.
BITRIX24_OAUTH_SPIKE_SCOPES=user_brief
BITRIX24_OAUTH_SPIKE_TOKEN_ENDPOINT=https://oauth.bitrix.info/oauth/token/
