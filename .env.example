# Milestone 1 works without secrets. Mock values are development-only.
APP_RUNTIME_MODE=mock
BITRIX24_MODE=mock

# Required only for future live integrations. Never prefix these with NEXT_PUBLIC_.
BITRIX24_PORTAL_URL=
BITRIX24_WEBHOOK_URL=
BITRIX24_TIMEZONE=Europe/Moscow

# Required only after Supabase Auth is connected.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
